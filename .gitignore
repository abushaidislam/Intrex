# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================================================================
# DEPENDENCIES
# =============================================================================
/node_modules
/.pnp
.pnp.js
.pnp.cjs
.yarn/install-state.gz
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.pnpm-store/
package-lock.json
yarn.lock

# =============================================================================
# BUILD OUTPUTS & DEPLOYMENT
# =============================================================================
# Next.js build output
/.next/
/out/

# Production build
/build
/dist

# Vercel deployment
.vercel

# =============================================================================
# ENVIRONMENT FILES (NEVER COMMIT SECRETS)
# =============================================================================
# All env files except example
.env
.env.*.local
.env.development
.env.test
.env.production

# Keep example files for documentation
!.env.example
!.env.local.example

# =============================================================================
# DEVELOPMENT & DEBUG
# =============================================================================
# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local development
*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# TypeScript
*.tsbuildinfo
next-env.d.ts

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
/coverage
.nyc_output

# Playwright test artifacts
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/

# =============================================================================
# DATABASE & DOCKER
# =============================================================================
# Local database data
postgres_data/
*.db
*.sqlite
*.sqlite3

# Docker override files
docker-compose.override.yml

# =============================================================================
# UPLOADS & TEMPORARY FILES
# =============================================================================
# Local file uploads (use Supabase/S3 in production)
/uploads/
/public/uploads/

# Temporary files
/tmp/
/temp/
*.tmp
*.temp

# Logs
/logs/
*.log

# =============================================================================
# CACHE & GENERATED FILES
# =============================================================================
# Cache directories
.cache/
.parcel-cache/
.eslintcache
.prettiercache

# Generated files
/generated/

# =============================================================================
# PACKAGE MANAGER ARTIFACTS
# =============================================================================
# pnpm workspace (not needed for single repo)
pnpm-workspace.yaml

# npm
.npm/

# yarn
.yarn-integrity

# =============================================================================
# SECURITY & KEYS
# =============================================================================
# Private keys
*.key
*.private
*.pem
!*.pem.example

# Certificates
*.crt
*.cer
*.der

# SSH
.ssh/

# =============================================================================
# MONITORING & REPORTING ARTIFACTS
# =============================================================================
# Local test reports
line/
/test-output/
/reports/

# =============================================================================
# MISCELLANEOUS
# =============================================================================
# macOS
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*.pid
*.seed
*.pid.lock